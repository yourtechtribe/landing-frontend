<div class='hero-wrapper w-screen relative'>
    <section class="hero flex items-start justify-center text-black h-full">
        <div class='left flex flex-col w-3/5 h-3/4 pr-20 pt-20 items-start justify-start gap-y-10'>
            <h2>Decisiones inteligentes al instante</h2>
            <h1>Rentabiliza tu restaurante con M.IA, tu asistente financiero virtual</h1>
            <h2 class=''>Que se conecta a TODOS tus sistemas y te apoya en la toma de decisiones.</h2>
            <a href='#footer'
          type="submit"
          class="btn-enviar text-center mb-18 w-92 text-white font-bold py-2 px-4 rounded-md  focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50"
        >
        ¡Entérate primero!
        </a>
            
        </div>
        <div class='logocontainer flex items-start justify-start pt-40 w-3/5'>
            <img src="movilfoto.jpg" alt="Logo" class="logo  w-full z-20 h-full mt-20">
        </div>
    </section>
    <div class='bg-image'></div>
</div>

    
<style>
     .btn-enviar{
      background-color:#204D74;
    }
    .btn-enviar:hover{
      background-color:#1B3E5C;
    }
    .hero-wrapper{
        height:120vh;
        background-color:#fff;
    }
     .hero{
        background-color: #fff;
        background-size: contain;
        background-repeat:no-repeat;
        width:100vw; 
        background-image: url('/last-removebg-preview.png');
        background-position:bottom left; 
        z-index:10;
    }
    
    .logocontainer{
        align-items: center;
        justify-content: center;
        padding: 0px;
        width: 30%;
        margin-top: 0px;
    }
    h1{
        font-weight:bold;
        font-size:100px;
        line-height:1;
    }
    h2{
        font-size:40px;
        line-height:1;
        color:#4A4A4A
    }
    .logo{
        border-radius:90px;
    }
  

    button{
        background-color:#204D74;
        color:white;
        font-weight:bold;
        padding:3px;
        border-radius:8px;
        height:50px;
    }
    @media(max-width:1339px){
        .hero-wrapper{
            height:110vh;
            display:flex;
            align-items:start;
            justify-content:start;
        }
        section{
            flex-direction:column-reverse;
            padding-top:0px;
            justify-content:start;


        }
        .left{
            width:100%;
            padding-left:40px;
            padding-right:40px;
        }
        .logocontainer{
            display:none;
        }
        /* .logocontainer{
            width:100%;
            padding-top:0px
            
        }
        .logo{
            width:50%;
        } */
    }
    @media(max-width:589px){
        section{
            justify-content:start;
        }
        .hero-wrapper{
            height:auto
            
        }
        .logocontainer{
            display:none;
        }
        h1{
        font-weight:bold;
        font-size:60px;
        line-height:1;
    }
    }
    @media(max-width:930px){
        section{
            height:100vh
        }
        h1{
            font-size:60px;
            width:90vw;
        }
        h2{
            font-size:40px
        }

    }
    @media(max-width:420px){
        h1{
            font-size:40px;
            text-align:start;
            width:100vw;
        }
        h2{
            font-size:26px
        }
        section{
            height:auto
        }
        .hero-wrapper{
            height:auto;
        }
        .left{
            height:100%;
            padding-top:0px;
            padding-left:0px;
        }
        .hero{padding-left:15px;}

    }
    
    

   
	
</style>
<script>
    document.querySelector('.btn-enviar')?.addEventListener('click', (event) => {
      event.preventDefault();
  
      const target = event.target as HTMLElement | null;
      if (!target) {
        console.error('El target del evento es null');
        return;
      }
  
      const targetId = target.getAttribute('href');
      if (!targetId) {
        console.error('El atributo href del target es null');
        return;
      }
  
      const targetElement = document.querySelector(targetId);
      if (!targetElement) {
        console.error(`No se encontró el elemento con el id: ${targetId}`);
        return;
      }
  
      targetElement.scrollIntoView({ behavior: 'smooth' });
    });
  </script>

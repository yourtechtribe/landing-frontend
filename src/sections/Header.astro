

<header class="header-container px-20">
    <h2>M.IA</h2>
    <a  href='#footer'   
          type="submit"
          class=" btn-enviar2 w-56 h-12  text-white font-bold flex items-center justify-center rounded-md  focus:outline-none focus:ring-2  "
        >
        ¡Entérate primero!
        </a>
</header>


<style>
     header{
        width:100vw;
        background-color:#204d74;
        height:70px;
        display:flex;
        justify-content:space-between;
        align-items:center
    }
    h2{
        font-weight:bold;
        padding-left:55px;
        font-size:36px;
      }
    .btn-enviar2{
      background-color:#FFFFFF;
      color:#4A4A4A
    }
    .btn-enviar2:hover{
      background-color:#F5F5F5;
    }

    @media(max-width:867px){
      h2{
        padding-left:0px;

      }
      header{
        padding-left:5px;
        padding-right:5px

      }


    }

    @media(max-width:501px){
      .btn-enviar2{
        width:150px;
        font-size:16px;
      }
      header{
        width:100vw;
      }

    }
</style>

<script>
  document.querySelector('.btn-enviar2')?.addEventListener('click', (event) => {
    event.preventDefault();

    const target = event.target as HTMLElement | null;
    if (!target) {
      console.error('El target del evento es null');
      return;
    }

    const targetId = target.getAttribute('href');
    if (!targetId) {
      console.error('El atributo href del target es null');
      return;
    }

    const targetElement = document.querySelector(targetId);
    if (!targetElement) {
      console.error(`No se encontró el elemento con el id: ${targetId}`);
      return;
    }

    targetElement.scrollIntoView({ behavior: 'smooth' });
  });
</script>
